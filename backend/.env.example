AUTH_GOOGLE_CLIENTID=
AUTH_GOOGLE_CLIENTSECRET=
DB_URL=postgres://postgres:secret@localhost:5432/pango?sslmode=disable
URL_BASEURL=https://localhost:3100

# Observability (OpenTelemetry). Optional: tracing and metrics only start when an OTLP/HTTP
# collector endpoint is set. Leave empty to disable. Example: http://localhost:4318
OTEL_EXPORTER_OTLP_ENDPOINT=
# Optional override; defaults to "pangostack-backend".
OTEL_SERVICE_NAME=